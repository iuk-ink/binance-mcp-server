{
  "name": "binance-mcp-server",
  "version": "2.0.0",
  "description": "MCP server for Binance Futures and technical indicators",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "binance-mcp-server": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "watch": "nodemon --exec tsx src/index.ts",
    "lint": "eslint src test",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "binance",
    "mcp",
    "model-context-protocol",
    "futures",
    "binance-futures",
    "trading",
    "technical-indicators"
  ],
  "author": {
    "name": "iuk-ink"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/iuk-ink/binance-mcp-server"
  },
  "homepage": "https://github.com/iuk-ink/binance-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/iuk-ink/binance-mcp-server/issues"
  },
  "files": [
    "dist",
    "README.md",
    "CLAUDE.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "binance-api-node": "^0.13.9",
    "dotenv": "^17.4.2",
    "trading-signals": "^7.4.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  }
}
