# =============================================================================
# Binance MCP Server — 环境变量配置模板
# =============================================================================
#
# 使用方法: 复制此文件为 .env 并填入你的配置值
#   cp .env.example .env
# =============================================================================

# ----- Binance API 认证（可选）-----
# 如果留空，服务器将只注册公开 API 工具和技术指标工具（共 57 个）
# 填入后可额外获得 19 个需要认证的期货交易工具（总计 76 个）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ----- 网络模式 -----
# true: 使用 Binance 测试网（推荐开发使用，虚拟资金）
# false: 使用 Binance 主网（真实资金，请谨慎操作）
BINANCE_TESTNET=true

# ----- 期货 REST API 端点（通常留空，自动根据 BINANCE_TESTNET 切换）-----
# 留空时自动选择:
#   testnet=true  → https://testnet.binancefuture.com
#   testnet=false → https://fapi.binance.com
HTTP_FUTURES_BASE=

# ----- 网络代理（可选，企业内网等场景使用）-----
# 支持 HTTP/HTTPS 代理
# 无需认证: HTTP_PROXY=http://proxy-host:port
# 需要认证: HTTP_PROXY=http://username:password@proxy-host:port
HTTP_PROXY=

# ----- 服务器标识 -----
MCP_SERVER_NAME=binance-mcp-server
MCP_SERVER_VERSION=2.0.2

# ----- 日志级别 -----
# debug: 输出所有日志（含错误堆栈）
# info: 常规日志（默认）
# warn: 仅警告和错误
# error: 仅错误
LOG_LEVEL=info
